{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run --name walletwright.docs next dev --turbopack",
    "build": "next build",
    "start": "next start -p 4000",
    "postinstall": "fumadocs-mdx",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
    "lint": "oxlint app lib components proxy.ts next.config.ts source.config.ts mdx-components.tsx",
    "clean": "rm -rf .next .source node_modules"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.10",
    "fumadocs-ui": "^16.9.3",
    "lucide-react": "^1.17.0",
    "next": "^16.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
