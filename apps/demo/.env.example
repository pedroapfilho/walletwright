# Copy to .env (gitignored) to run the Privy spec against your own app.
# Create one at dashboard.privy.io: enable wallet login, allow http://localhost:3000.
# Without it, the demo page falls back to Privy's shared public test app id (fine for
# clicking by hand, too rate-limited for the automated spec) and the spec skips.
VITE_PRIVY_APP_ID=YOUR_PRIVY_APP_ID_HERE
