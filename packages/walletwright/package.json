{
  "name": "walletwright",
  "version": "0.1.0",
  "description": "Playwright wallet automation for MetaMask, Phantom, and Slush across EVM, Solana, and Sui. Connect and sign in real browser extensions.",
  "keywords": [
    "e2e",
    "ethereum",
    "metamask",
    "phantom",
    "playwright",
    "slush",
    "solana",
    "sui",
    "testing",
    "wallet",
    "web3"
  ],
  "license": "MIT",
  "author": "Pedro Filho <pedro@filho.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroapfilho/walletwright.git",
    "directory": "packages/walletwright"
  },
  "bin": {
    "walletwright": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./chain": {
      "types": "./dist/chain.d.mts",
      "default": "./dist/chain.mjs"
    },
    "./mock": {
      "types": "./dist/mock.d.mts",
      "default": "./dist/mock.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "prepack": "pnpm run build",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "classic-level": "^1.4.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@repo/config-vitest": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^25.9.1",
    "prool": "^0.2.10",
    "typescript": "^6.0.3",
    "viem": "^2.21.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.48",
    "prool": ">=0.2",
    "viem": ">=2"
  },
  "peerDependenciesMeta": {
    "prool": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  }
}
